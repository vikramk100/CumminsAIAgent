<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:layout="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  controllerName="cummins.dispatcher.controller.Main">

  <VBox fitContainer="true">
    <Bar>
      <contentLeft>
        <Button
          id="backToWorkOrders"
          type="Back"
          text="Back to Work Orders"
          press="onNavBack" />
      </contentLeft>
      <contentRight>
        <Button text="Edit Work Order" type="Transparent" icon="sap-icon://edit" press="onEditWorkOrder" />
        <Button text="Delete Work Order" type="Reject" icon="sap-icon://delete" press="onDeleteWorkOrder" />
      </contentRight>
    </Bar>
  <uxap:ObjectPageLayout id="ObjectPage" showFooter="false" useIconTabBar="true">
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:expandedHeading>
          <VBox class="sapUiMediumMargin">
            <Title
              level="H2"
              text="Equipment {dispatch>/context_summary/equipmentId}" />
            <Text
              text="Failure: {dispatch>/context_summary/failure_label}"
              wrapping="false" />
            <HBox alignItems="Center" class="sapUiSmallMarginTop">
              <Text text="Risk level" class="sapUiTinyMarginEnd" />
              <ObjectStatus
                text="{dispatch>/ui/criticalityText}"
                state="{dispatch>/ui/criticalityState}" />
            </HBox>
            <HBox alignItems="Center" class="sapUiTinyMarginTop">
              <Text text="Confidence" class="sapUiTinyMarginEnd" />
              <ProgressIndicator
                width="180px"
                percentValue="{dispatch>/ui/confidencePercent}"
                displayValue="{dispatch>/ui/confidenceDisplay}"
                state="{dispatch>/ui/criticalityState}" />
            </HBox>
          </VBox>
        </uxap:expandedHeading>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:sections>
      <uxap:ObjectPageSection title="Work Order Overview">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <layout:SimpleForm
                editable="false"
                layout="ResponsiveGridLayout"
                labelSpanL="4"
                labelSpanM="4"
                emptySpanL="1"
                emptySpanM="1"
                columnsL="2"
                columnsM="2">
                <Label text="Work Order" />
                <ObjectIdentifier
                  title="{dispatch>/workOrderDetail/orderId}"
                  text="{= ${dispatch>/workOrderDetail/orderDate} ? 'Created: ' + ${dispatch>/workOrderDetail/orderDate} : ''}" />
                <Label text="Equipment" />
                <Text text="{dispatch>/workOrderDetail/equipmentId}" />
                <Label text="Status" />
                <ObjectStatus
                  text="{dispatch>/workOrderDetail/status}"
                  state="{= ${dispatch>/workOrderDetail/status} === 'Completed' ? 'Success' : (${dispatch>/workOrderDetail/status} === 'Created' ? 'Information' : 'Warning') }" />
                <Label text="Priority" />
                <Text text="{dispatch>/workOrderDetail/priority}" />
                <Label text="Technician" />
                <Text text="{dispatch>/workOrderDetail/technician}" />
                <Label text="Days to Resolve" />
                <Text text="{dispatch>/workOrderDetail/daysToSolve}" />
              </layout:SimpleForm>
            </VBox>
          </uxap:ObjectPageSubSection>
          <uxap:ObjectPageSubSection title="Issue &amp; Equipment Details">
            <VBox class="sapUiSmallMargin">
              <Panel
                headerText="Issue Description"
                expandable="true"
                expanded="true"
                class="sapUiSmallMarginBottom">
                <Text
                  text="{dispatch>/workOrderDetail/issueDescription}"
                  wrapping="true" />
              </Panel>
              <Panel
                headerText="Equipment Telemetry Snapshot"
                expandable="true"
                expanded="false">
                <layout:SimpleForm
                  editable="false"
                  layout="ResponsiveGridLayout"
                  labelSpanL="4"
                  labelSpanM="4"
                  emptySpanL="1"
                  emptySpanM="1"
                  columnsL="2"
                  columnsM="2">
                  <Label text="Process Temperature" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Process_Temperature}" />
                  <Label text="Air Temperature" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Air_Temperature}" />
                  <Label text="Rotational Speed" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Rotational_Speed}" />
                  <Label text="Torque" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Torque}" />
                  <Label text="Tool Wear" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Tool_Wear}" />
                </layout:SimpleForm>
              </Panel>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Confirmations">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <Toolbar>
                <Title text="Confirmations" level="H4" />
                <ToolbarSpacer />
                <Button
                  text="Add Confirmation"
                  type="Emphasized"
                  icon="sap-icon://add"
                  press="onAddConfirmation" />
              </Toolbar>
              <Table
                id="ConfirmationsTable"
                items="{dispatch>/workOrderDetail/confirmations}">
                <columns>
                  <Column width="12rem"><Text text="Confirmation ID" /></Column>
                  <Column><Text text="Text" /></Column>
                  <Column width="8rem"><Text text="Status" /></Column>
                  <Column width="8rem" hAlign="End"><Text text="Actual Work (h)" /></Column>
                  <Column width="10rem"><Text text="Confirmed At" /></Column>
                  <Column width="8rem"></Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{dispatch>confirmationId}" />
                      <Text text="{dispatch>confirmationText}" wrapping="true" />
                      <ObjectStatus text="{dispatch>status}" state="Information" />
                      <Text text="{dispatch>actualWork}" />
                      <Text text="{dispatch>confirmedAt}" />
                      <HBox>
                        <Button icon="sap-icon://edit" type="Transparent" press="onEditConfirmation" />
                        <Button icon="sap-icon://delete" type="Transparent" press="onDeleteConfirmation" />
                      </HBox>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Insights">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                <Button
                  text="Talk to AI"
                  type="Emphasized"
                  icon="sap-icon://discussion-2"
                  press="onOpenAiChat" />
                <Button
                  text="Show Thought Process"
                  type="Transparent"
                  icon="sap-icon://inspect"
                  press="onShowThoughtProcess" />
              </HBox>
              <Text
                text="{dispatch>/mission_briefing/root_cause_analysis}"
                wrapping="true" />
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Preparation">
        <uxap:subSections>
          <!-- Technician Tools Section -->
          <uxap:ObjectPageSubSection title="Technician Tools">
            <VBox class="sapUiSmallMargin">
              <HBox justifyContent="SpaceBetween" alignItems="Center" class="sapUiSmallMarginBottom">
                <HBox>
                  <Button
                    text="Talk to AI"
                    type="Emphasized"
                    icon="sap-icon://discussion-2"
                    press="onOpenAiChat"
                    class="sapUiTinyMarginEnd" />
                  <Button
                    text="Show Thought Process"
                    type="Transparent"
                    icon="sap-icon://inspect"
                    press="onShowThoughtProcess" />
                </HBox>
                <HBox>
                  <Button
                    text="Select All"
                    type="Transparent"
                    icon="sap-icon://multiselect-all"
                    press="onSelectAllTools"
                    class="sapUiTinyMarginEnd" />
                  <Button
                    text="Deselect All"
                    type="Transparent"
                    icon="sap-icon://multiselect-none"
                    press="onDeselectAllTools"
                    class="sapUiTinyMarginEnd" />
                  <Button
                    id="addToolBtn"
                    text="Add Tool"
                    type="Transparent"
                    icon="sap-icon://add"
                    press="onAddTool" />
                </HBox>
              </HBox>
              <Table
                id="ToolsTable"
                items="{prep>/recommendedTools}"
                mode="MultiSelect"
                selectionChange="onToolSelectionChange"
                growing="true"
                growingThreshold="10">
                <headerToolbar>
                  <OverflowToolbar>
                    <Title text="Required Tools" level="H4" />
                    <ToolbarSpacer />
                    <Label text="Selected: " />
                    <ObjectNumber number="{prep>/selectedToolsCount}" unit="tools" emphasized="true" />
                  </OverflowToolbar>
                </headerToolbar>
                <columns>
                  <Column width="40%">
                    <Text text="Tool Name" />
                  </Column>
                  <Column width="20%">
                    <Text text="Category" />
                  </Column>
                  <Column width="15%">
                    <Text text="Location" />
                  </Column>
                  <Column width="15%">
                    <Text text="Availability" />
                  </Column>
                  <Column width="10%" hAlign="Center">
                    <Text text="Have It" />
                  </Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{prep>name}" />
                      <Text text="{prep>category}" />
                      <Text text="{prep>location}" />
                      <ObjectStatus
                        text="{prep>availability}"
                        state="{= ${prep>availability} === 'in_stock' ? 'Success' : (${prep>availability} === 'low_stock' ? 'Warning' : 'Error')}"
                        icon="{= ${prep>availability} === 'in_stock' ? 'sap-icon://sys-enter-2' : (${prep>availability} === 'low_stock' ? 'sap-icon://alert' : 'sap-icon://error')}" />
                      <CheckBox
                        selected="{prep>hasItem}"
                        select="onToolHasItemChange">
                        <customData>
                          <core:CustomData key="toolId" value="{prep>toolId}" writeToDom="false" />
                        </customData>
                      </CheckBox>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </uxap:ObjectPageSubSection>

          <!-- Spare Parts Section -->
          <uxap:ObjectPageSubSection title="Spare Parts">
            <VBox class="sapUiSmallMargin">
              <HBox justifyContent="End" alignItems="Center" class="sapUiSmallMarginBottom">
                <Button
                  text="Select All"
                  type="Transparent"
                  icon="sap-icon://multiselect-all"
                  press="onSelectAllParts"
                  class="sapUiTinyMarginEnd" />
                <Button
                  text="Deselect All"
                  type="Transparent"
                  icon="sap-icon://multiselect-none"
                  press="onDeselectAllParts"
                  class="sapUiTinyMarginEnd" />
                <Button
                  id="addPartBtn"
                  text="Add Part"
                  type="Transparent"
                  icon="sap-icon://add"
                  press="onAddPart" />
              </HBox>
              <Table
                id="PartsTable"
                items="{prep>/recommendedParts}"
                mode="MultiSelect"
                selectionChange="onPartSelectionChange"
                growing="true"
                growingThreshold="10">
                <headerToolbar>
                  <OverflowToolbar>
                    <Title text="Recommended Spare Parts" level="H4" />
                    <ToolbarSpacer />
                    <Label text="Selected: " />
                    <ObjectNumber number="{prep>/selectedPartsCount}" unit="parts" emphasized="true" />
                    <ToolbarSeparator />
                    <Label text="Total: " />
                    <ObjectNumber number="{prep>/selectedPartsTotal}" unit="USD" emphasized="true" state="Information" />
                  </OverflowToolbar>
                </headerToolbar>
                <columns>
                  <Column width="30%">
                    <Text text="Part Name" />
                  </Column>
                  <Column width="15%">
                    <Text text="Part Number" />
                  </Column>
                  <Column width="12%">
                    <Text text="Category" />
                  </Column>
                  <Column width="10%" hAlign="Right">
                    <Text text="Unit Price" />
                  </Column>
                  <Column width="13%">
                    <Text text="Availability" />
                  </Column>
                  <Column width="10%">
                    <Text text="Lead Time" />
                  </Column>
                  <Column width="10%" hAlign="Center">
                    <Text text="Have It" />
                  </Column>
                </columns>
                <items>
                  <ColumnListItem>
                    <cells>
                      <Text text="{prep>name}" />
                      <Text text="{prep>partNumber}" />
                      <Text text="{prep>category}" />
                      <ObjectNumber number="{prep>unitPrice}" unit="USD" />
                      <ObjectStatus
                        text="{prep>availability}"
                        state="{= ${prep>availability} === 'in_stock' ? 'Success' : (${prep>availability} === 'low_stock' ? 'Warning' : 'Error')}"
                        icon="{= ${prep>availability} === 'in_stock' ? 'sap-icon://sys-enter-2' : (${prep>availability} === 'low_stock' ? 'sap-icon://alert' : 'sap-icon://error')}" />
                      <Text text="{prep>leadTimeDays} days" />
                      <CheckBox
                        selected="{prep>hasItem}"
                        select="onPartHasItemChange">
                        <customData>
                          <core:CustomData key="partId" value="{prep>partId}" writeToDom="false" />
                        </customData>
                      </CheckBox>
                    </cells>
                  </ColumnListItem>
                </items>
              </Table>
            </VBox>
          </uxap:ObjectPageSubSection>

          <!-- Checkout Section -->
          <uxap:ObjectPageSubSection title="Checkout">
            <VBox class="sapUiSmallMargin">
              <Panel headerText="Order Summary" class="sapUiSmallMarginBottom">
                <VBox class="sapUiSmallMargin">
                  <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                    <Text text="Selected Tools:" />
                    <Text text="{prep>/selectedToolsCount}" design="Bold" />
                  </HBox>
                  <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                    <Text text="Selected Spare Parts:" />
                    <Text text="{prep>/selectedPartsCount}" design="Bold" />
                  </HBox>
                  <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
                    <Text text="Total Parts Cost:" />
                    <ObjectNumber number="{prep>/selectedPartsTotal}" unit="USD" emphasized="true" state="Information" />
                  </HBox>
                </VBox>
              </Panel>
              <HBox justifyContent="Center">
                <Button
                  text="Proceed to Checkout"
                  type="Emphasized"
                  icon="sap-icon://cart"
                  press="onProceedToCheckout"
                  enabled="{= ${prep>/selectedToolsCount} > 0 || ${prep>/selectedPartsCount} > 0}" />
              </HBox>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Documentation">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <Panel
              headerText="Manual Reference Snippet"
              expandable="true"
              expanded="true"
              class="sapUiSmallMargin">
              <FormattedText htmlText="{dispatch>/ui/manualSnippetHtml}" />
            </Panel>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Timeline">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <List
                id="TimelineList"
                headerText="Work Order Timeline"
                items="{dispatch>/workOrderDetail/timeline}">
                <CustomListItem>
                  <VBox class="sapUiSmallMarginBottom">
                    <HBox justifyContent="SpaceBetween">
                      <Text
                        text="{dispatch>title}"
                        design="Bold" />
                      <Text text="{dispatch>at}" />
                    </HBox>
                    <Text
                      text="{dispatch>description}"
                      wrapping="true" />
                  </VBox>
                </CustomListItem>
              </List>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
    </uxap:sections>
  </uxap:ObjectPageLayout>

  <!-- AI Chat dialog -->
  <Dialog
    id="AiChatDialog"
    title="Talk to AI Assistant"
    contentWidth="550px"
    contentHeight="480px"
    resizable="true"
    draggable="true"
    verticalScrolling="false">
    <content>
      <VBox height="100%" class="sapUiSmallMargin">
        <!-- Header info -->
        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
          <core:Icon src="sap-icon://da-2" size="1.5rem" color="#0854a0" class="sapUiTinyMarginEnd" />
          <Text text="Ask any question about this work order, equipment, or repair procedures." wrapping="true" />
        </HBox>
        
        <!-- Question input -->
        <VBox class="sapUiTinyMarginTop">
          <Label text="Your Question" design="Bold" />
          <TextArea
            id="AiChatInput"
            rows="3"
            width="100%"
            placeholder="e.g., What are the common causes of this fault code?" />
          <Button
            text="Ask AI"
            type="Emphasized"
            icon="sap-icon://initiative"
            press="onSendAiQuestion"
            class="sapUiSmallMarginTop" />
        </VBox>
        
        <!-- Answer section with scroll -->
        <Panel
          headerText="AI Response"
          expandable="false"
          class="sapUiSmallMarginTop"
          height="220px">
          <ScrollContainer
            height="100%"
            width="100%"
            vertical="true"
            horizontal="false">
            <VBox class="sapUiTinyMargin">
              <FormattedText
                htmlText="{path: 'dispatch>/ui/chatLastAnswer', formatter: '.formatter.textToHtml'}"
                width="100%" />
            </VBox>
          </ScrollContainer>
        </Panel>
      </VBox>
    </content>
    <buttons>
      <Button text="Close" press="onCloseAiChat" type="Transparent" />
    </buttons>
  </Dialog>

  <!-- Edit Work Order dialog -->
  <Dialog id="EditWorkOrderDialog" title="Edit Work Order" contentWidth="400px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Equipment ID" />
        <Input id="EditWO_equipmentId" value="" />
        <Label text="Status" class="sapUiTinyMarginTop" />
        <Select id="EditWO_status">
          <core:Item key="Created" text="Created" />
          <core:Item key="Released" text="Released" />
          <core:Item key="In Progress" text="In Progress" />
          <core:Item key="Completed" text="Completed" />
          <core:Item key="Cancelled" text="Cancelled" />
        </Select>
        <Label text="Priority" class="sapUiTinyMarginTop" />
        <Select id="EditWO_priority">
          <core:Item key="1" text="1 (Highest)" />
          <core:Item key="2" text="2" />
          <core:Item key="3" text="3" />
          <core:Item key="4" text="4" />
          <core:Item key="5" text="5 (Lowest)" />
        </Select>
        <Label text="Actual Work (hours)" class="sapUiTinyMarginTop" />
        <Input id="EditWO_actualWork" type="Number" value="0" />
      </VBox>
    </content>
    <buttons>
      <Button text="Cancel" press="onCloseEditWorkOrder" />
      <Button text="Save" type="Emphasized" press="onSaveWorkOrder" />
    </buttons>
  </Dialog>

  <!-- Add / Edit Confirmation dialog -->
  <Dialog
    id="ConfirmationDialog"
    title="Add Confirmation"
    contentWidth="420px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Confirmation Text" />
        <TextArea id="Confirmation_Text" rows="4" width="100%" value="" />
        <Label text="Status" class="sapUiTinyMarginTop" />
        <Select id="Confirmation_Status" selectedKey="Submitted">
          <core:Item key="Draft" text="Draft" />
          <core:Item key="Submitted" text="Submitted" />
          <core:Item key="Approved" text="Approved" />
        </Select>
        <Label text="Actual Work (hours)" class="sapUiTinyMarginTop" />
        <Input id="Confirmation_ActualWork" type="Number" value="0" />
      </VBox>
    </content>
    <buttons>
      <Button text="Cancel" press="onCloseConfirmationDialog" />
      <Button text="Save" type="Emphasized" press="onSaveConfirmation" />
    </buttons>
  </Dialog>

  <!-- Thought process dialog -->
  <Dialog
    id="ThoughtProcessDialog"
    title="AI Reasoning Process"
    contentWidth="650px"
    contentHeight="500px"
    resizable="true"
    draggable="true"
    verticalScrolling="false">
    <content>
      <VBox height="100%" class="sapUiSmallMargin">
        <!-- Header -->
        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
          <core:Icon src="sap-icon://process" size="1.5rem" color="#0854a0" class="sapUiTinyMarginEnd" />
          <Title text="How this insight was generated" level="H5" />
        </HBox>
        
        <!-- Scrollable thought process content -->
        <ScrollContainer
          height="380px"
          width="100%"
          vertical="true"
          horizontal="false"
          class="sapUiTinyMarginTop">
          <VBox class="sapUiSmallMargin">
            <FormattedText
              htmlText="{path: 'dispatch>/mission_briefing/thought_process', formatter: '.formatter.textToHtml'}"
              width="100%" />
          </VBox>
        </ScrollContainer>
        
        <!-- Feedback section -->
        <HBox
          justifyContent="Center"
          alignItems="Center"
          class="sapUiSmallMarginTop">
          <Text text="Was this reasoning helpful?" class="sapUiTinyMarginEnd" />
          <Button
            icon="sap-icon://thumb-up"
            type="Accept"
            tooltip="Yes, this looks correct"
            press="onThoughtFeedbackUp" />
          <Button
            icon="sap-icon://thumb-down"
            type="Reject"
            tooltip="No, this looks incorrect"
            press="onThoughtFeedbackDown"
            class="sapUiTinyMarginBegin" />
        </HBox>
      </VBox>
    </content>
    <buttons>
      <Button text="Close" press="onCloseThoughtProcess" type="Transparent" />
    </buttons>
  </Dialog>

  <!-- Checkout Dialog -->
  <Dialog
    id="CheckoutDialog"
    title="Checkout - Tools &amp; Spare Parts"
    contentWidth="600px"
    contentHeight="auto">
    <content>
      <VBox class="sapUiSmallMargin">
        <!-- Order Details -->
        <Panel headerText="Order Details" expandable="false">
          <VBox class="sapUiSmallMargin">
            <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
              <Text text="Work Order:" />
              <Text text="{prep>/workOrderId}" design="Bold" />
            </HBox>
            <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
              <Text text="Equipment:" />
              <Text text="{prep>/equipmentId}" design="Bold" />
            </HBox>
          </VBox>
        </Panel>

        <!-- Selected Tools Summary -->
        <Panel headerText="Selected Tools ({prep>/selectedToolsCount})" expandable="true" expanded="true" class="sapUiSmallMarginTop">
          <List
            items="{prep>/checkoutTools}"
            noDataText="No tools selected">
            <StandardListItem
              title="{prep>name}"
              description="{prep>category}"
              icon="sap-icon://wrench"
              info="{prep>location}"
              infoState="Information" />
          </List>
        </Panel>

        <!-- Selected Parts Summary -->
        <Panel headerText="Selected Spare Parts ({prep>/selectedPartsCount})" expandable="true" expanded="true" class="sapUiSmallMarginTop">
          <List
            items="{prep>/checkoutParts}"
            noDataText="No parts selected">
            <StandardListItem
              title="{prep>name}"
              description="{prep>partNumber}"
              icon="sap-icon://product"
              info="${prep>unitPrice} USD"
              infoState="Information" />
          </List>
        </Panel>

        <!-- Total -->
        <Panel headerText="Order Total" class="sapUiSmallMarginTop">
          <VBox class="sapUiSmallMargin">
            <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
              <Text text="Tools to Pick Up:" />
              <ObjectNumber number="{prep>/selectedToolsCount}" unit="items" />
            </HBox>
            <HBox justifyContent="SpaceBetween" class="sapUiTinyMarginBottom">
              <Text text="Parts to Order:" />
              <ObjectNumber number="{prep>/selectedPartsCount}" unit="items" />
            </HBox>
            <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginTop">
              <Text text="Total Parts Cost:" design="Bold" />
              <ObjectNumber number="{prep>/selectedPartsTotal}" unit="USD" emphasized="true" state="Information" />
            </HBox>
          </VBox>
        </Panel>

        <!-- Notes -->
        <VBox class="sapUiSmallMarginTop">
          <Label text="Notes (optional)" />
          <TextArea
            id="checkoutNotes"
            rows="3"
            width="100%"
            placeholder="Add any special instructions or notes..." />
        </VBox>
      </VBox>
    </content>
    <buttons>
      <Button
        text="Place Order"
        type="Emphasized"
        icon="sap-icon://accept"
        press="onPlaceOrder" />
      <Button text="Cancel" press="onCloseCheckout" />
    </buttons>
  </Dialog>

  <!-- Order Success Dialog -->
  <Dialog
    id="OrderSuccessDialog"
    title="Order Placed"
    type="Message"
    state="Success"
    contentWidth="400px">
    <content>
      <VBox class="sapUiSmallMargin" alignItems="Center">
        <core:Icon
          src="sap-icon://accept"
          size="4rem"
          color="#107e3e"
          class="sapUiMediumMarginBottom" />
        <Title text="Order Placed Successfully!" level="H3" class="sapUiSmallMarginBottom" />
        <Text text="Your preparation order has been submitted." class="sapUiSmallMarginBottom" />
        <ObjectStatus
          text="Order ID: {prep>/lastOrderId}"
          state="Success"
          icon="sap-icon://sys-enter-2" />
      </VBox>
    </content>
    <buttons>
      <Button text="Done" type="Emphasized" press="onCloseOrderSuccess" />
    </buttons>
  </Dialog>

  <!-- Add Tool Dialog -->
  <Dialog
    id="AddToolDialog"
    title="Add Tool to List"
    contentWidth="400px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Select Tool" required="true" />
        <Select
          id="addToolSelect"
          width="100%"
          items="{
            path: 'allTools>/results',
            sorter: { path: 'name' }
          }">
          <core:Item key="{allTools>toolId}" text="{allTools>name} ({allTools>category})" />
        </Select>
      </VBox>
    </content>
    <buttons>
      <Button text="Add" type="Emphasized" press="onConfirmAddTool" />
      <Button text="Cancel" press="onCancelAddTool" />
    </buttons>
  </Dialog>

  <!-- Add Part Dialog -->
  <Dialog
    id="AddPartDialog"
    title="Add Spare Part to List"
    contentWidth="400px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Select Spare Part" required="true" />
        <Select
          id="addPartSelect"
          width="100%"
          items="{
            path: 'allParts>/results',
            sorter: { path: 'name' }
          }">
          <core:Item key="{allParts>partId}" text="{allParts>name} ({allParts>partNumber})" />
        </Select>
      </VBox>
    </content>
    <buttons>
      <Button text="Add" type="Emphasized" press="onConfirmAddPart" />
      <Button text="Cancel" press="onCancelAddPart" />
    </buttons>
  </Dialog>

  </VBox>
</mvc:View>

