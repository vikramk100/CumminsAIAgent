<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:uxap="sap.uxap"
  xmlns:layout="sap.ui.layout.form"
  xmlns:core="sap.ui.core"
  controllerName="cummins.dispatcher.controller.Main">

  <uxap:ObjectPageLayout id="ObjectPage" showFooter="false" useIconTabBar="true">
    <uxap:headerTitle>
      <uxap:ObjectPageDynamicHeaderTitle>
        <uxap:expandedHeading>
          <VBox class="sapUiMediumMargin">
            <Title
              level="H2"
              text="Equipment {dispatch>/context_summary/equipmentId}" />
            <Text
              text="Failure: {dispatch>/context_summary/failure_label}"
              wrapping="false" />
            <HBox alignItems="Center" class="sapUiSmallMarginTop">
              <Text text="Risk level" class="sapUiTinyMarginEnd" />
              <ObjectStatus
                text="{dispatch>/ui/criticalityText}"
                state="{dispatch>/ui/criticalityState}" />
            </HBox>
            <HBox alignItems="Center" class="sapUiTinyMarginTop">
              <Text text="Confidence" class="sapUiTinyMarginEnd" />
              <ProgressIndicator
                width="180px"
                percentValue="{dispatch>/ui/confidencePercent}"
                displayValue="{dispatch>/ui/confidenceDisplay}"
                state="{dispatch>/ui/criticalityState}" />
            </HBox>
          </VBox>
        </uxap:expandedHeading>
      </uxap:ObjectPageDynamicHeaderTitle>
    </uxap:headerTitle>

    <uxap:sections>
      <uxap:ObjectPageSection title="Work Order Overview">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <layout:SimpleForm
                editable="false"
                layout="ResponsiveGridLayout"
                labelSpanL="4"
                labelSpanM="4"
                emptySpanL="1"
                emptySpanM="1"
                columnsL="2"
                columnsM="2">
                <Label text="Work Order" />
                <ObjectIdentifier
                  title="{dispatch>/workOrderDetail/orderId}"
                  text="{= ${dispatch>/workOrderDetail/orderDate} ? 'Created: ' + ${dispatch>/workOrderDetail/orderDate} : ''}" />
                <Label text="Equipment" />
                <Text text="{dispatch>/workOrderDetail/equipmentId}" />
                <Label text="Status" />
                <ObjectStatus
                  text="{dispatch>/workOrderDetail/status}"
                  state="{= ${dispatch>/workOrderDetail/status} === 'Completed' ? 'Success' : (${dispatch>/workOrderDetail/status} === 'Created' ? 'Information' : 'Warning') }" />
                <Label text="Priority" />
                <Text text="{dispatch>/workOrderDetail/priority}" />
                <Label text="Technician" />
                <Text text="{dispatch>/workOrderDetail/technician}" />
                <Label text="Days to Resolve" />
                <Text text="{dispatch>/workOrderDetail/daysToSolve}" />
              </layout:SimpleForm>
            </VBox>
          </uxap:ObjectPageSubSection>
          <uxap:ObjectPageSubSection title="Issue &amp; Equipment Details">
            <VBox class="sapUiSmallMargin">
              <Panel
                headerText="Issue Description"
                expandable="true"
                expanded="true"
                class="sapUiSmallMarginBottom">
                <Text
                  text="{dispatch>/workOrderDetail/issueDescription}"
                  wrapping="true" />
              </Panel>
              <Panel
                headerText="Equipment Telemetry Snapshot"
                expandable="true"
                expanded="false">
                <layout:SimpleForm
                  editable="false"
                  layout="ResponsiveGridLayout"
                  labelSpanL="4"
                  labelSpanM="4"
                  emptySpanL="1"
                  emptySpanM="1"
                  columnsL="2"
                  columnsM="2">
                  <Label text="Process Temperature" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Process_Temperature}" />
                  <Label text="Air Temperature" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Air_Temperature}" />
                  <Label text="Rotational Speed" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Rotational_Speed}" />
                  <Label text="Torque" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Torque}" />
                  <Label text="Tool Wear" />
                  <Text text="{dispatch>/workOrderDetail/telemetry/Tool_Wear}" />
                </layout:SimpleForm>
              </Panel>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Insights">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <Text
                text="{dispatch>/mission_briefing/root_cause_analysis}"
                wrapping="true" />
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Preparation">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <List
              id="ToolsList"
              headerText="Required Tools"
              items="{dispatch>/ui/tools}">
              <CustomListItem>
                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                  <CheckBox
                    selected="{dispatch>checked}"
                    select="onPressToolKitCheck">
                    <customData>
                      <core:CustomData key="toolName" value="{dispatch>name}" writeToDom="false" />
                    </customData>
                  </CheckBox>
                  <DisplayListItem label="{dispatch>name}" value="" />
                </HBox>
              </CustomListItem>
            </List>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Documentation">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <Panel
              headerText="Manual Reference Snippet"
              expandable="true"
              expanded="true"
              class="sapUiSmallMargin">
              <FormattedText htmlText="{dispatch>/ui/manualSnippetHtml}" />
            </Panel>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>

      <uxap:ObjectPageSection title="Timeline">
        <uxap:subSections>
          <uxap:ObjectPageSubSection>
            <VBox class="sapUiSmallMargin">
              <List
                id="TimelineList"
                headerText="Work Order Timeline"
                items="{dispatch>/workOrderDetail/timeline}">
                <CustomListItem>
                  <VBox class="sapUiSmallMarginBottom">
                    <HBox justifyContent="SpaceBetween">
                      <Text
                        text="{dispatch>title}"
                        design="Bold" />
                      <Text text="{dispatch>at}" />
                    </HBox>
                    <Text
                      text="{dispatch>description}"
                      wrapping="true" />
                  </VBox>
                </CustomListItem>
              </List>
            </VBox>
          </uxap:ObjectPageSubSection>
        </uxap:subSections>
      </uxap:ObjectPageSection>
    </uxap:sections>
  </uxap:ObjectPageLayout>
</mvc:View>

