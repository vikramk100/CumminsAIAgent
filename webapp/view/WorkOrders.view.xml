<mvc:View
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:core="sap.ui.core"
  controllerName="cummins.dispatcher.controller.WorkOrders">
  <Page title="Work Orders and Confirmations" showNavButton="true" navButtonPress="onNavBack">
    <content>
      <VBox class="sapUiSmallMargin">
        <Toolbar>
          <Title text="Work Orders" level="H2" />
          <ToolbarSpacer />
          <Label text="Status" />
          <Select id="statusFilter" width="10rem" change="onFilterChange">
            <items>
              <core:Item key="" text="All" />
              <core:Item key="Created" text="Created" />
              <core:Item key="Released" text="Released" />
              <core:Item key="In Progress" text="In Progress" />
              <core:Item key="Completed" text="Completed" />
              <core:Item key="Cancelled" text="Cancelled" />
            </items>
          </Select>
          <ToolbarSpacer />
          <Label text="Priority" />
          <Select id="priorityFilter" width="8rem" change="onFilterChange">
            <items>
              <core:Item key="" text="All" />
              <core:Item key="1" text="1 (Highest)" />
              <core:Item key="2" text="2" />
              <core:Item key="3" text="3" />
              <core:Item key="4" text="4" />
              <core:Item key="5" text="5 (Lowest)" />
            </items>
          </Select>
          <ToolbarSpacer />
          <SearchField
            id="WorkOrderSearch"
            width="20rem"
            placeholder="Search by Work Order or Equipment"
            search="onSearch"
            liveChange="onSearch" />
          <Button
            text="Reset"
            type="Transparent"
            icon="sap-icon://refresh"
            press="onClearFilters" />
        </Toolbar>

        <Toolbar>
          <ToolbarSpacer />
          <Button
            text="Create"
            type="Emphasized"
            icon="sap-icon://add"
            press="onOpenCreateWorkOrder" />
          <Button
            text="Edit"
            type="Transparent"
            icon="sap-icon://edit"
            press="onEditWorkOrder"
            id="btnEditWO" />
          <Button
            text="Delete"
            type="Reject"
            icon="sap-icon://delete"
            press="onDeleteSelectedWorkOrder"
            id="btnDeleteWO" />
        </Toolbar>

        <Table
          id="WorkOrdersTable"
          class="sapUiSizeCondensed"
          mode="SingleSelectLeft"
          selectionChange="onWorkOrderSelectionChange"
          headerText="Work Orders"
          items="{wo>/workOrders}">
          <columns>
            <Column width="10rem">
              <Text text="Work Order" />
            </Column>
            <Column width="10rem">
              <Text text="Equipment" />
            </Column>
            <Column width="8rem">
              <Text text="Status" />
            </Column>
            <Column width="6rem" hAlign="End">
              <Text text="Priority" />
            </Column>
            <Column width="8rem" hAlign="End">
              <Text text="Actual Work (h)" />
            </Column>
            <Column width="18rem">
              <Text text="Confirmations" />
            </Column>
          </columns>
          <items>
            <ColumnListItem type="Active" press="onWorkOrderPress" vAlign="Top">
              <cells>
                <ObjectIdentifier
                  title="{wo>orderId}"
                  text="{= 'Created: ' + (${wo>orderDate} || '')}" />
                <Text text="{wo>equipmentId}" />
                <ObjectStatus
                  text="{wo>status}"
                  state="{= ${wo>status} === 'Completed' ? 'Success' : (${wo>status} === 'Created' ? 'Information' : 'Warning') }" />
                <Text text="{wo>priority}" />
                <Text text="{wo>actualWork}" />
                <Panel
                  expandable="true"
                  expanded="false"
                  headerText="{= 'Confirmations (' + ((${wo>confirmations}.length || 0)) + ')' }"
                  class="sapUiTinyMarginTop">
                  <List items="{wo>confirmations}">
                    <StandardListItem
                      title="{wo>confirmationText}"
                      description="{= 'Actual Work: ' + (${wo>actualWork} || 0) + ' h'}"
                      icon="sap-icon://accept" />
                  </List>
                </Panel>
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </VBox>
    </content>
  </Page>

  <Dialog
    id="CreateWorkOrderDialog"
    title="Create Work Order"
    contentWidth="480px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Equipment ID" />
        <Input id="CreateWO_equipmentId" value="" placeholder="e.g. M-001" />
        <Label text="Issue Description" class="sapUiTinyMarginTop" />
        <TextArea
          id="CreateWO_issueDescription"
          rows="4"
          width="100%"
          placeholder="Describe the issue to get category suggestions from ML"
          value="" />
        <Button
          text="Suggest categories (ML)"
          type="Transparent"
          icon="sap-icon://competitor"
          press="onSuggestCategories"
          class="sapUiTinyMarginTop" />
        <List
          id="CreateWO_categoriesList"
          headerText="Suggested categories (select one or more)"
          mode="MultiSelect"
          visible="false"
          class="sapUiTinyMarginTop">
          <StandardListItem title="{createForm>name}" selected="{createForm>selected}" />
        </List>
        <Label text="Status" class="sapUiTinyMarginTop" />
        <Select id="CreateWO_status" selectedKey="Created">
          <core:Item key="Created" text="Created" />
          <core:Item key="Released" text="Released" />
          <core:Item key="In Progress" text="In Progress" />
          <core:Item key="Completed" text="Completed" />
          <core:Item key="Cancelled" text="Cancelled" />
        </Select>
        <Label text="Priority" class="sapUiTinyMarginTop" />
        <Select id="CreateWO_priority" selectedKey="2">
          <core:Item key="1" text="1 (Highest)" />
          <core:Item key="2" text="2" />
          <core:Item key="3" text="3" />
          <core:Item key="4" text="4" />
          <core:Item key="5" text="5 (Lowest)" />
        </Select>
        <Label text="Actual Work (hours)" class="sapUiTinyMarginTop" />
        <Input id="CreateWO_actualWork" type="Number" value="0" />
      </VBox>
    </content>
    <buttons>
      <Button text="Cancel" press="onCloseCreateWorkOrder" />
      <Button text="Create" type="Emphasized" press="onCreateWorkOrderSubmit" />
    </buttons>
  </Dialog>

  <Dialog
    id="EditWorkOrderDialog"
    title="Edit Work Order"
    contentWidth="480px">
    <content>
      <VBox class="sapUiSmallMargin">
        <Label text="Equipment ID" />
        <Input id="EditWO_equipmentId" value="" />
        <Label text="Issue Description" class="sapUiTinyMarginTop" />
        <TextArea id="EditWO_issueDescription" rows="3" width="100%" value="" />
        <Label text="Status" class="sapUiTinyMarginTop" />
        <Select id="EditWO_status">
          <core:Item key="Created" text="Created" />
          <core:Item key="Released" text="Released" />
          <core:Item key="In Progress" text="In Progress" />
          <core:Item key="Completed" text="Completed" />
          <core:Item key="Cancelled" text="Cancelled" />
        </Select>
        <Label text="Priority" class="sapUiTinyMarginTop" />
        <Select id="EditWO_priority">
          <core:Item key="1" text="1 (Highest)" />
          <core:Item key="2" text="2" />
          <core:Item key="3" text="3" />
          <core:Item key="4" text="4" />
          <core:Item key="5" text="5 (Lowest)" />
        </Select>
        <Label text="Actual Work (hours)" class="sapUiTinyMarginTop" />
        <Input id="EditWO_actualWork" type="Number" value="0" />
      </VBox>
    </content>
    <buttons>
      <Button text="Cancel" press="onCloseEditWorkOrder" />
      <Button text="Save" type="Emphasized" press="onSaveWorkOrder" />
    </buttons>
  </Dialog>
</mvc:View>

